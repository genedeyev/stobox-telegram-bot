# ============================================================================
# Stobox AI Telegram Community Manager — environment template
# Copy to .env and fill in.  NEVER commit the real .env (see .gitignore).
# In production, source these from a secrets manager / vault, not a file.
# ============================================================================

# --- Telegram ---------------------------------------------------------------
TELEGRAM_BOT_TOKEN=            # from @BotFather
TELEGRAM_ADMIN_USER_IDS=       # comma-separated numeric user ids, e.g. 12345,67890
TELEGRAM_ADMIN_USERNAMES=      # optional: comma-separated @usernames, e.g. arevikd
                               # (convenient, but IDs are more secure — usernames can change)

# --- LLM providers ----------------------------------------------------------
# Reasoning defaults to Anthropic (see config.yaml -> llm.reasoning.provider).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=                # used for embeddings by default; also enables OpenAI reasoning swap

# --- Database (Postgres + pgvector) -----------------------------------------
# LEAVE EMPTY for local testing (in-memory store). For production set a real
# Postgres+pgvector URL (e.g. Supabase), NOT localhost, e.g.:
#   postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=

# --- Runtime ----------------------------------------------------------------
STOBOX_ENV=development          # development | staging | production
LOG_LEVEL=INFO
CONFIG_PATH=config/config.yaml
DOCS_PATH=docs
PROMPTS_PATH=config/prompts
STOBOX_SYNC_ON_BOOT=0           # 1 = crawl stobox.io + GitHub on startup (slower boot)
STOBOX_VALUATION=              # optional: current Eqvista company valuation mark shown in [FRESHNESS]

# --- Knowledge sync (web + GitHub ingestion) --------------------------------
GITHUB_TOKEN=                   # optional; raises GitHub API rate limits for repo sync
WEBHOOK_SECRET=                 # shared secret for the /api/reingest self-update webhook (stobox-web)

# --- Email (/email write-ups + MQL summaries to info@stobox.io) -------------
# Two ways to send; if neither is set, leads are still captured and the user is
# told the team will follow up. Resend is preferred when RESEND_API_KEY is set.
#
# Option 1 — Resend (recommended: just an API key, no SMTP server):
RESEND_API_KEY=                 # re_... from resend.com
EMAIL_FROM=                     # e.g. Stoby <stoby@stobox.io> — must be on a
                                # Resend-verified domain (or leave blank to use
                                # the onboarding@resend.dev test sender)
#
# Option 2 — SMTP (used only if RESEND_API_KEY is unset):
SMTP_HOST=                      # e.g. smtp.sendgrid.net
SMTP_PORT=587                   # 587 (STARTTLS) or 465 (SSL)
SMTP_USER=
SMTP_PASS=

# --- Optional integrations (future) ----------------------------------------
CRM_WEBHOOK_URL=                # lead handoff (HubSpot/Salesforce webhook)
